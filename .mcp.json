{
  "name": "churn-predictor-ai-mcp",
  "description": "> **By [MEOK AI Labs](https://meok.ai)** \u2014 Comprehensive customer churn prediction and retention analytics.",
  "version": "1.0.0",
  "tools": [
    {
      "name": "predict_churn",
      "description": "Predict churn risk for a customer",
      "parameters": {
        "type": "object",
        "properties": {
          "customer_id": {
            "type": "string"
          },
          "last_login_days": {
            "type": "integer"
          },
          "support_tickets_last_30d": {
            "type": "integer"
          },
          "nps_score": {
            "type": "integer"
          },
          "usage_decline_percent": {
            "type": "integer"
          },
          "payment_failures": {
            "type": "integer"
          },
          "tenure_months": {
            "type": "integer"
          }
        },
        "required": []
      }
    },
    {
      "name": "batch_predict_churn",
      "description": "Predict churn for multiple customers",
      "parameters": {
        "type": "object",
        "properties": {
          "customers": {
            "type": "array"
          }
        },
        "required": []
      }
    },
    {
      "name": "get_customer_risk",
      "description": "Get current risk score for a customer",
      "parameters": {
        "type": "object",
        "properties": {
          "customer_id": {
            "type": "string"
          }
        },
        "required": [
          "customer_id"
        ]
      }
    },
    {
      "name": "track_customer",
      "description": "Add customer to churn tracking",
      "parameters": {
        "type": "object",
        "properties": {
          "customer_id": {
            "type": "string"
          },
          "initial_data": {
            "type": "object"
          }
        },
        "required": [
          "customer_id"
        ]
      }
    },
    {
      "name": "update_customer_signals",
      "description": "Update customer behavioral signals",
      "parameters": {
        "type": "object",
        "properties": {
          "customer_id": {
            "type": "string"
          },
          "signals": {
            "type": "object"
          }
        },
        "required": [
          "customer_id"
        ]
      }
    },
    {
      "name": "get_at_risk_customers",
      "description": "Get all customers above risk threshold",
      "parameters": {
        "type": "object",
        "properties": {
          "threshold": {
            "type": "integer"
          },
          "limit": {
            "type": "integer"
          }
        },
        "required": []
      }
    },
    {
      "name": "create_retention_action",
      "description": "Create a retention action for at-risk customer",
      "parameters": {
        "type": "object",
        "properties": {
          "customer_id": {
            "type": "string"
          },
          "action_type": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        },
        "required": [
          "customer_id",
          "action_type"
        ]
      }
    },
    {
      "name": "get_retention_actions",
      "description": "Get retention actions for a customer",
      "parameters": {
        "type": "object",
        "properties": {
          "customer_id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          }
        },
        "required": []
      }
    },
    {
      "name": "update_retention_action",
      "description": "Update status of retention action",
      "parameters": {
        "type": "object",
        "properties": {
          "action_id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          }
        },
        "required": [
          "action_id",
          "status"
        ]
      }
    },
    {
      "name": "get_churn_analytics",
      "description": "Get overall churn analytics",
      "parameters": {
        "type": "object",
        "properties": {
          "period": {
            "type": "string"
          }
        },
        "required": []
      }
    },
    {
      "name": "get_cohort_retention",
      "description": "Get cohort retention analysis",
      "parameters": {
        "type": "object",
        "properties": {
          "cohort_month": {
            "type": "string"
          }
        },
        "required": []
      }
    },
    {
      "name": "simulate_intervention",
      "description": "Simulate impact of retention action",
      "parameters": {
        "type": "object",
        "properties": {
          "customer_id": {
            "type": "string"
          },
          "action_type": {
            "type": "string"
          }
        },
        "required": [
          "customer_id"
        ]
      }
    },
    {
      "name": "get_risk_trends",
      "description": "Get risk score trends over time",
      "parameters": {
        "type": "object",
        "properties": {
          "customer_id": {
            "type": "string"
          },
          "days": {
            "type": "integer"
          }
        },
        "required": [
          "customer_id"
        ]
      }
    }
  ]
}